rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lojas — qualquer um pode ler (necessário para o login),
    // escrita apenas via Console do Firebase
    match /stores/{storeId} {
      allow read: if true;
      allow write: if false;
    }

    // Dados do dia — leitura e escrita livres (app interno)
    match /days/{dayId} {
      allow read, write: if true;
    }

    // Config admin — leitura livre (necessário para validar login),
    // escrita apenas via Console do Firebase
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
